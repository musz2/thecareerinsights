---
/* Brand social links (full-colour icons): LinkedIn, WhatsApp, Instagram.
   Used in the footer Connect column and the mobile FlowMenu footer.
   The Instagram gradient id is namespaced per-instance so multiple copies on
   one page don't collide. */
const uid = `ig-${Math.random().toString(36).slice(2, 9)}`;
const whatsapp = "https://wa.me/15105458417";
---

<a class="footer-social" href="https://www.linkedin.com/company/the-career-insights/" target="_blank" rel="noopener noreferrer" aria-label="Open The Career Insights LinkedIn page">
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <rect width="24" height="24" rx="4.5" fill="#0A66C2" />
    <path fill="#fff" d="M6.94 8.96H3.78v10.28h3.16V8.96ZM5.36 4.76a1.84 1.84 0 1 0 0 3.68 1.84 1.84 0 0 0 0-3.68Zm13.9 8.58c0-3.1-1.66-4.54-3.87-4.54-1.78 0-2.58.98-3.03 1.67V8.96H9.34v10.28h3.15v-5.08c0-1.34.25-2.64 1.92-2.64 1.64 0 1.66 1.54 1.66 2.72v5h3.16v-5.9Z" />
  </svg>
  LinkedIn
</a>

<a class="footer-social" href={whatsapp} target="_blank" rel="noopener noreferrer" aria-label="Chat with The Career Insights on WhatsApp">
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <circle cx="12" cy="12" r="12" fill="#25D366" />
    <path fill="#fff" d="M17.5 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.26-.46-2.4-1.48-.89-.79-1.49-1.77-1.66-2.07-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.06 2.88 1.21 3.08c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.69.25-1.28.17-1.41-.07-.12-.27-.2-.57-.35z" />
  </svg>
  WhatsApp
</a>

<a class="footer-social" href="https://www.instagram.com/thecareerinsightshub/" target="_blank" rel="noopener noreferrer" aria-label="Open The Career Insights Instagram page">
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <defs>
      <radialGradient id={uid} cx="0.3" cy="1.05" r="1.25">
        <stop offset="0" stop-color="#FEDA77" />
        <stop offset="0.25" stop-color="#F58529" />
        <stop offset="0.5" stop-color="#DD2A7B" />
        <stop offset="0.75" stop-color="#8134AF" />
        <stop offset="1" stop-color="#515BD4" />
      </radialGradient>
    </defs>
    <rect width="24" height="24" rx="6" fill={`url(#${uid})`} />
    <rect x="6.3" y="6.3" width="11.4" height="11.4" rx="3.4" fill="none" stroke="#fff" stroke-width="1.5" />
    <circle cx="12" cy="12" r="3" fill="none" stroke="#fff" stroke-width="1.5" />
    <circle cx="16.4" cy="7.6" r="1.05" fill="#fff" />
  </svg>
  Instagram
</a>
