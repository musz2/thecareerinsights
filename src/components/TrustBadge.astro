---
interface Props {
  size?: "regular" | "compact";
}
const { size = "regular" } = Astro.props;
---

<div class={`tbadge tbadge-${size}`} data-trust-badge={size === "regular" ? "true" : undefined} aria-label="E-Verified U.S. Employer badge">
  <svg class="tbadge-everify-logo" viewBox="0 0 520 160" role="img" aria-label="E-Verified">
    <g class="everify-symbol" transform="translate(18 27)">
      <rect x="0" y="0" width="70" height="106" rx="9" fill="#163d75" />
      <g fill="#ffffff">
        <circle cx="18" cy="18" r="3.9" /><circle cx="34" cy="18" r="3.9" /><circle cx="50" cy="18" r="3.9" />
        <circle cx="18" cy="34" r="3.9" /><circle cx="34" cy="34" r="3.9" /><circle cx="50" cy="34" r="3.9" />
        <circle cx="18" cy="50" r="3.9" /><circle cx="34" cy="50" r="3.9" /><circle cx="50" cy="50" r="3.9" />
        <circle cx="18" cy="66" r="3.9" /><circle cx="34" cy="66" r="3.9" /><circle cx="50" cy="66" r="3.9" />
        <circle cx="18" cy="82" r="3.9" /><circle cx="34" cy="82" r="3.9" /><circle cx="50" cy="82" r="3.9" />
      </g>
      <rect x="80" y="0" width="96" height="27" rx="4" fill="#cf2332" />
      <rect x="80" y="40" width="83" height="27" rx="4" fill="#cf2332" />
      <rect x="80" y="80" width="104" height="27" rx="4" fill="#cf2332" />
    </g>
    <text x="224" y="96" fill="#1a4b89" font-family="Arial, Helvetica, sans-serif" font-size="72" font-weight="800" letter-spacing="-3">-Verified</text>
  </svg>
</div>
