---
/* "Why Choose The Career Insights?" trust section.
   Dark cinematic background, gold accents, glass depth.
   Left: heading + benefits. Right: floating custom trust badge. */
import TrustBadge from "./TrustBadge.astro";
import { trustBenefits } from "../data/site";
---

<section class="trust-section" data-chapter="Contact" data-cinematic-scene="trust">
  <div class="trust-grid shell">
    <div class="trust-copy">
      <p class="eyebrow gold">Trusted partnership</p>
      <h2 data-mask-reveal>Why Choose The Career Insights?</h2>
      <p class="trust-lede">
        We combine expertise, innovation, and dedication to deliver exceptional results
        for professionals, businesses, universities, and workforce partners.
      </p>
      <ul class="trust-benefits">
        {trustBenefits.map((benefit) => (
          <li data-reveal>
            <span class="trust-icon" aria-hidden="true">{benefit.code}</span>
            <div>
              <h3>{benefit.title}</h3>
              <p>{benefit.copy}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
    <div class="trust-badge-col">
      <TrustBadge />
    </div>
  </div>
</section>
