---
interface Benefit { title: string; copy: string }
interface Props {
  title: string;
  subtitle: string;
  intro: string;
  body: string;
  bullets: string[];
  stat: string;
  statLabel: string;
  benefits: Benefit[];
  theme?: string;
}
import { Image } from "astro:assets";
import detailPhoto from "../assets/images/tci-workforce-operations.png";
const { title, subtitle, intro, body, bullets, stat, statLabel, benefits, theme = "red" } = Astro.props;
---

<section class={`detail-hero detail-${theme}`}>
  <div class="detail-hero-photo" aria-hidden="true"><Image src={detailPhoto} alt="" widths={[768, 1280, 1672]} sizes="100vw" format="webp" quality={70} loading="eager" fetchpriority="high" /></div>
  <div class="detail-hero-pattern" aria-hidden="true"></div>
  <div class="shell" data-reveal><p class="eyebrow light">Solutions</p><h1>{title}</h1><p>{subtitle}</p><a class="button button-red" href="/contact">Meet with an expert</a></div>
</section>
<section class="section dotted-section detail-intro">
  <div class="shell detail-grid">
    <div class="rich-copy"><h2>{intro}</h2><p>{body}</p><a class="text-link" href="/contact">Build your solution <span>↗</span></a></div>
    <ul class="check-list large">{bullets.map((bullet) => <li>{bullet}</li>)}</ul>
  </div>
</section>
<section class="stat-band">
  <strong class="sr-only">{stat}</strong>
  <div class="stat-marquee" aria-hidden="true">
    <div class="stat-marquee-track">{Array.from({ length: 12 }).map(() => <span>{stat}<i>✦</i></span>)}</div>
  </div>
  <div class="shell stat-band-foot"><p>{statLabel}</p><a class="button button-dark" href="/contact">Talk to a specialist</a></div>
</section>
<section class="section section-gray"><div class="shell centered-heading"><p class="eyebrow">Program value</p><h2>Built for measurable workforce outcomes.</h2></div><div class="shell benefit-grid">{benefits.map((benefit) => <article data-reveal><span aria-hidden="true">•</span><h3>{benefit.title}</h3><p>{benefit.copy}</p></article>)}</div></section>
