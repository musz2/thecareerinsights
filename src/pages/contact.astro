---
import BaseLayout from "../layouts/BaseLayout.astro";
import { contactInfo } from "../data/site";
---
<BaseLayout title="Contact The Career Insights" description="Tell The Career Insights about your staffing, talent, technology, or career needs.">
  <section class="page-hero contact-hero" data-chapter="Contact"><div class="shell"><p class="eyebrow light">Contact us</p><h1>How can we fill your staffing needs?</h1><p>Share the requirement, timeline, and operating context. We will connect you with the right talent or technology specialist.</p><div class="button-row contact-cta-row"><a class="button button-red" href={`mailto:${contactInfo.email}`}>Email Us <span>↗</span></a><a class="button button-ghost" href="tel:+13022312961">Call Desk</a><a class="button button-gold" href="#contact-form-anchor">Book Consultation</a></div></div></section>
  <section class="section dotted-section contact-section" id="contact-form-anchor"><div class="shell contact-grid"><div><p class="eyebrow">Get in touch</p><h2>Let’s move the work forward.</h2><p class="lead">TCI supports organizations across the United States and globally with temporary staffing, direct hire, contingent recruiting, total talent, and technology services.</p><div class="contact-details"><p><span>Email us</span><a href="mailto:info@thecareerinsights.com">{contactInfo.email}</a></p><p><span>Call us</span><a href="tel:+13022312961">Desk: {contactInfo.desk}</a><a href="tel:+13024992545">Contact: {contactInfo.mobile}</a><small>{contactInfo.hours}</small></p><p><span>Talent database</span><strong>500,000+ pre-vetted IT professionals</strong></p></div></div><form class="contact-form" data-contact-form><div class="form-row"><label><span>Name</span><input type="text" name="name" autocomplete="name" required /></label><label><span>Work email</span><input type="email" name="email" autocomplete="email" required /></label></div><label><span>What are you exploring?</span><select name="interest"><option>Recruitment Process Outsourcing</option><option>Contingent Workforce</option><option>Total Talent Solutions</option><option>Technology Services</option><option>Career Guidance</option><option>University or Public Sector Program</option></select></label><label><span>Tell us about the requirement</span><textarea name="message" rows="6" required></textarea></label><div class="form-submit"><p data-form-status aria-live="polite">We usually respond within two business days.</p><button class="button button-red" type="submit">Send request <span>↗</span></button></div></form></div></section>
  <section class="section office-section"><div class="shell"><div class="section-heading"><div><p class="eyebrow">Visit us</p><h2>Two locations.<br />One connected team.</h2></div><p>Our United States and India teams support clients, candidates, and delivery programs across regions and time zones.</p></div><div class="office-grid"><article data-reveal><span>United States</span><h3>{contactInfo.usAddress[0]}</h3><p>{contactInfo.usAddress[1]}</p><a href="https://www.google.com/maps/search/?api=1&query=8+The+Green+Dover+DE+19901" target="_blank" rel="noreferrer">Open in maps ↗</a></article><article data-reveal><span>India</span><h3>{contactInfo.indiaAddress[0]}</h3><p>{contactInfo.indiaAddress[1]}</p><a href="https://www.google.com/maps/search/?api=1&query=Hyderabad+Telangana+India" target="_blank" rel="noreferrer">Open in maps ↗</a></article></div></div></section>
  <section class="talent-database"><div class="shell"><div><p class="eyebrow light">Exclusive talent database</p><h2>Access deployment-ready professionals.</h2></div><p>Tap into a curated database of more than 500,000 pre-vetted IT professionals. Candidate qualifications, certifications, and security clearances are verified for public, private, and commercial needs.</p></div></section>
</BaseLayout>
