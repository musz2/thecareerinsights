---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { solutionLinks } from "../../data/site";
---
<BaseLayout title="Talent Solutions | The Career Insights" description="RPO, contingent workforce, and total talent solutions designed around your business.">
  <section class="page-hero"><div class="shell"><p class="eyebrow light">Solutions</p><h1>Capabilities that move your workforce forward.</h1><p>Future-focused talent programs that strengthen decision-making, improve delivery, and create sustainable growth.</p></div></section>
  <section class="section dotted-section"><div class="shell centered-heading"><p class="eyebrow">A flexible model</p><h2>Solutions built around your goals.</h2><p>No two organizations are alike. Whether you are growing quickly, redesigning recruitment, or integrating new technology into the talent ecosystem, we shape the right solution and scale it alongside the business.</p></div><div class="shell solution-index-grid">{solutionLinks.map((item, index) => <a href={item.href} data-reveal><span aria-hidden="true">•</span><h3>{item.label}</h3><p>{index === 0 ? "A strategic partnership that manages the full recruitment lifecycle with precision, transparency, and speed." : index === 1 ? "Flexible contractor programs with centralized vendor management, disciplined cost control, and end-to-end compliance." : "Integrated workforce planning across permanent, temporary, contract, and internal talent."}</p><b>Learn more ↗</b></a>)}</div></section>
  <section class="section feature-section"><div class="shell split-intro"><div><p class="eyebrow light">Our approach</p><h2>One partner. Every talent category.</h2></div><div class="rich-copy light-copy"><p class="lead">We connect talent attraction, assessment, onboarding, compliance, intelligence, and internal mobility in one adaptable framework.</p><p>That gives leaders a clearer view of demand, cost, quality, and opportunity while giving candidates a more consistent experience.</p><a class="button button-red" href="/contact">Design your program</a></div></div></section>
</BaseLayout>
