---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SolutionPage from "../../components/SolutionPage.astro";
const bullets = ["End-to-end internal and external candidate pipelines", "Permanent, contract, temporary, and internal talent", "Expert definition of the ideal candidate profile", "Streamlined temporary-to-permanent transitions", "Dedicated talent pools for critical roles"];
const benefits = [{ title: "Talent Pool Development", copy: "Build and maintain dedicated sourcing plans and talent communities for critical roles." }, { title: "Data-Driven Decisions", copy: "Use market analytics and workforce intelligence to improve sourcing decisions." }, { title: "Centralized Management", copy: "Bring sourcing, interviewing, tracking, selection, and onboarding into one operating view." }, { title: "Internal Mobility", copy: "Connect existing capability with emerging opportunities across the organization." }];
---
<BaseLayout title="Total Talent Solutions | The Career Insights" description="Integrated talent management across permanent, temporary, contract, and internal teams."><SolutionPage title="Total Talent Solutions" subtitle="One platform. Every talent type. Seamless workforce management." intro="Comprehensive solutions designed for every talent category." body="TCI provides a unified framework for strategic workforce planning across permanent, temporary, contract, and internal placements. We improve sourcing effectiveness, support internal mobility, and simplify the transition from temporary to permanent employment." bullets={bullets} stat="Total visibility" statLabel="A connected view of permanent, contingent, temporary, and internal talent." benefits={benefits} theme="talent" /></BaseLayout>
