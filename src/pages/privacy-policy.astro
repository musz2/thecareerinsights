---
import BaseLayout from "../layouts/BaseLayout.astro";
import { contactInfo } from "../data/site";

const sections = [
  { id: "information-we-collect", title: "Information We Collect" },
  { id: "how-we-use-information", title: "How We Use Information" },
  { id: "cookies-and-analytics", title: "Cookies & Analytics" },
  { id: "sharing-and-disclosure", title: "Sharing & Disclosure" },
  { id: "data-security", title: "Data Security" },
  { id: "data-retention", title: "Data Retention" },
  { id: "your-rights", title: "Your Rights & Choices" },
  { id: "childrens-privacy", title: "Children's Privacy" },
  { id: "policy-updates", title: "Updates to This Policy" },
  { id: "contact-us", title: "Contact Us" }
];
---

<BaseLayout
  title="Privacy Policy | The Career Insights"
  description="How The Career Insights collects, uses, protects, and shares personal information across our website and services."
>
  <section class="page-hero legal-hero" data-chapter="Contact">
    <div class="shell">
      <p class="eyebrow light">Legal</p>
      <h1>Privacy Policy</h1>
      <p>How we collect, use, and protect your information. Last updated: June 2026.</p>
    </div>
  </section>

  <section class="section legal-section">
    <div class="shell legal-grid">
      <nav class="legal-toc" aria-label="Table of contents">
        <p>On this page</p>
        {sections.map((s) => <a href={`#${s.id}`}>{s.title}</a>)}
      </nav>

      <div class="legal-body rich-copy">
        <p class="lead">
          The Career Insights LLC ("TCI", "we", "us") respects your privacy. This policy explains
          what information we collect through thecareerinsights.com and our services, how we use
          it, and the choices you have. This document is provided as a general template and should
          be reviewed by qualified legal counsel before being relied upon.
        </p>

        <h2 id="information-we-collect">Information We Collect</h2>
        <p>We may collect information you provide directly, such as your name, email address, phone number, and the details you submit through our contact and consultation forms. We may also collect professional information you choose to share with us, such as a resume, skills, certifications, or career goals, when you engage our career, training, or staffing services.</p>

        <h2 id="how-we-use-information">How We Use Information</h2>
        <p>We use the information we collect to respond to inquiries, provide career guidance, training, staffing, and technology services, match candidates with opportunities, improve our website and offerings, and communicate with you about services you have requested. We do not sell personal information.</p>

        <h2 id="cookies-and-analytics">Cookies & Analytics</h2>
        <p>Our website may use cookies and similar technologies to remember preferences and understand how visitors use the site. You can control cookies through your browser settings; disabling them may affect some site functionality.</p>

        <h2 id="sharing-and-disclosure">Sharing & Disclosure</h2>
        <p>We may share information with service providers who support our operations, with clients when you ask us to represent you for an opportunity, and when required by law. Any sharing is limited to what is necessary for the stated purpose.</p>

        <h2 id="data-security">Data Security</h2>
        <p>We use reasonable administrative, technical, and physical safeguards designed to protect personal information. No method of transmission or storage is completely secure, and we cannot guarantee absolute security.</p>

        <h2 id="data-retention">Data Retention</h2>
        <p>We retain personal information for as long as needed to fulfill the purposes described in this policy, comply with legal obligations, resolve disputes, and enforce agreements, after which it is deleted or anonymized.</p>

        <h2 id="your-rights">Your Rights & Choices</h2>
        <p>Depending on your location, you may have rights to access, correct, or delete your personal information, or to object to certain processing. To exercise these rights, contact us using the details below and we will respond in accordance with applicable law.</p>

        <h2 id="childrens-privacy">Children's Privacy</h2>
        <p>Our website and services are intended for adults and working professionals. We do not knowingly collect personal information from children under 13. If you believe a child has provided us information, please contact us so we can remove it.</p>

        <h2 id="policy-updates">Updates to This Policy</h2>
        <p>We may update this Privacy Policy from time to time. The updated version will be posted on this page with a revised date. Continued use of the website after changes indicates acceptance of the updated policy.</p>

        <h2 id="contact-us">Contact Us</h2>
        <p>
          For privacy questions or requests: Email <a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>,
          Desk <a href="tel:+13022312961">{contactInfo.desk}</a> ({contactInfo.hours}).
          Offices: {contactInfo.usAddress.join(", ")} and {contactInfo.indiaAddress.join(", ")}.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
