---
import "@fontsource-variable/archivo";
import "@fontsource-variable/manrope";
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import CinematicFooter from "../components/CinematicFooter.astro";
import AmbientBackground from "../components/AmbientBackground.astro";
import ChapterProgress from "../components/ChapterProgress.astro";
import PremiumCursor from "../components/PremiumCursor.astro";
import AIAssistant from "../components/AIAssistant.astro";
import LogoMark from "../components/LogoMark.astro";
import { contactInfo } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "The Career Insights | Career Intelligence for Future-Ready Professionals",
  description = "Career intelligence, technology training, workforce solutions, and digital transformation for professionals and organizations."
} = Astro.props;

const siteOrigin = (Astro.site ?? new URL("https://thecareerinsights.com")).origin;
/* Per-page canonical + og:url (previously hardcoded to the homepage) */
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://thecareerinsights.com").href;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${siteOrigin}/#organization`,
  name: "The Career Insights",
  url: siteOrigin,
  logo: `${siteOrigin}/favicon.svg`,
  image: `${siteOrigin}/og-image.jpg`,
  description,
  email: contactInfo.email,
  telephone: contactInfo.desk,
  address: [
    {
      "@type": "PostalAddress",
      streetAddress: contactInfo.usAddress[0],
      addressLocality: "Dover",
      addressRegion: "DE",
      postalCode: "19901",
      addressCountry: "US"
    },
    {
      "@type": "PostalAddress",
      streetAddress: contactInfo.indiaAddress.join(", "),
      addressLocality: "Hyderabad",
      addressRegion: "Telangana",
      addressCountry: "IN"
    }
  ],
  areaServed: ["United States", "India", "Global"]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#08090b" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="The Career Insights" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL("/og-image.jpg", Astro.site ?? "https://thecareerinsights.com").href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="The Career Insights — talent solutions and technology services" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#d1212e" />
    <meta name="application-name" content="The Career Insights" />
    <meta name="apple-mobile-web-app-title" content="TCI" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} is:inline />
  </head>
  <body id="top">
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div class="cinematic-atmosphere" aria-hidden="true"><i></i><i></i><i></i></div>
    <AmbientBackground />
    <div class="site-loader" data-site-loader aria-hidden="true">
      <LogoMark class="loader-logo" />
      <p>Connecting talent to opportunity</p>
      <div><i></i></div>
    </div>
    <SiteHeader />
    <ChapterProgress />
    <main id="main-content"><slot /></main>
    <CinematicFooter />
    <a class="back-to-top" href="#top" aria-label="Back to top">↑</a>
    <AIAssistant />
    <PremiumCursor />
    <script>
      import "../scripts/site.ts";
    </script>
  </body>
</html>
